{
  "functions": {
    "api/go.php": {
      "runtime": "vercel-php@0.7.2",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/go",
      "dest": "/api/go.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/go.php"
    }
  ],
  "regions": ["hkg1", "sin1", "nrt1"],
  "headers": [
    {
      "source": "/api/go.php",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ]
}
